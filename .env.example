# ==============================================
# BrandScaling Node.js Backend - Environment Variables
# ==============================================
# Rename this file to .env and fill in your values
# DO NOT commit .env to version control!

# Server Configuration
NODE_ENV=production
PORT=3000
API_VERSION=v1

# Database Configuration - AWS Aurora PostgreSQL
DB_HOST=your-database-host.rds.amazonaws.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_MAX_CONNECTIONS=20
DB_IDLE_TIMEOUT=60000
DB_CONNECTION_TIMEOUT=20000

# CORS Configuration
ALLOWED_ORIGINS=*

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Quiz Configuration
QUIZ_RETAKE_DAYS=7
MAX_QUIZ_LAYERS=7

# JWT Secret (for admin/agent authentication)
JWT_SECRET=your-jwt-secret-key-here

# RevenueCat Webhook Secret
REVENUECAT_WEBHOOK_SECRET=your-revenuecat-webhook-secret-here
